# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ipynb_checkpoints/

# ── Environments ──────────────────────────────────────────────────────────
.venv/
env/
environment.local.yml

# ── Caches ──────────────────────────────────────────────────────────────────
nilearn_cache/
.cache/

# ── Data (never committed — referenced by config/datasets.yaml) ─────────────
data/

# Large imaging files anywhere
*.nii
*.nii.gz
*.dtseries.nii
*.dscalar.nii
*.dlabel.nii
*.gii
*.mat

# Computed arrays / figures
*.npy
*.npz
*.pdf
*.png

# ── Atlases: ignore large files; keep the small committed refs + READMEs ────
atlases/**
!atlases/README.md
!atlases/**/*.txt
!atlases/**/*.tsv

# ── Results: tracked in this repo, overriding the type rules above ──────────
# Commit figures (*.png) and arrays (*.npy/*.npz) under results/.
!results/**
# ...but keep PDFs out: they duplicate the PNGs and are large (~49 MB).
results/**/*.pdf
# Exception: the q1 consensus tree has no PNG equivalent, so keep its PDF.
!results/MSC/surface/q1/consensus_tree.pdf

# ── OS cruft ──────────────────────────────────────────────────────────────
.DS_Store
__MACOSX/
