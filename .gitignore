# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ipynb_checkpoints/

# ── Environments ──────────────────────────────────────────────────────────
.venv/
env/
environment.local.yml

# ── Caches ──────────────────────────────────────────────────────────────────
nilearn_cache/
.cache/

# ── Data & outputs (never committed — referenced by config/datasets.yaml) ───
data/
results/

# Large imaging files anywhere
*.nii
*.nii.gz
*.dtseries.nii
*.dscalar.nii
*.dlabel.nii
*.gii
*.mat

# Computed arrays / figures
*.npy
*.npz
*.pdf
*.png

# ── Atlases: ignore large files; keep the small committed refs + READMEs ────
atlases/**
!atlases/README.md
!atlases/**/*.txt
!atlases/**/*.tsv

# ── OS cruft ──────────────────────────────────────────────────────────────
.DS_Store
__MACOSX/
